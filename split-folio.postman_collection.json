    {
      "name": "Portfolio Stocks CRUD",
      "item": [
        {
          "name": "Batch Upsert Stocks",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"stocks\": [\n    {\n      \"ticker\": \"AAPL\",\n      \"allocationPercentage\": 50\n    },\n    {\n      \"ticker\": \"TSLA\",\n      \"allocationPercentage\": 30\n    },\n    {\n      \"ticker\": \"GOOGL\",\n      \"allocationPercentage\": 20\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/portfolios/{{portfolioId}}/stocks/batch",
              "host": ["{{baseUrl}}"],
              "path": ["portfolios", "{{portfolioId}}", "stocks", "batch"]
            },
            "description": "Fetches existing stocks for portfolio, merges with incoming stocks (existing.merge(new) so incoming overrides existing), validates total weight <= 100%, batch inserts/updates stocks inside transaction, and updates portfolio allocated_weight and is_complete status."
          },
          "response": []
        },
        {
          "name": "Add Stock to Portfolio (Upsert Single)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "if (jsonData && jsonData.id) {",
                  "    pm.collectionVariables.set('stockId', jsonData.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ticker\": \"GOOGL\",\n  \"allocationPercentage\": 20,\n  \"customMarketPrice\": 175.25\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/portfolios/{{portfolioId}}/stocks",
              "host": ["{{baseUrl}}"],
              "path": ["portfolios", "{{portfolioId}}", "stocks"]
            },
            "description": "Adds or updates an individual stock allocation in a portfolio and recalculates allocated_weight and is_complete status"
          },
          "response": []
        },
        {
          "name": "Get Portfolio Stocks",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/portfolios/{{portfolioId}}/stocks",
              "host": ["{{baseUrl}}"],
              "path": ["portfolios", "{{portfolioId}}", "stocks"]
            },
            "description": "Lists all stock allocations for a portfolio"
          },
          "response": []
        },
        {
          "name": "Get Portfolio Stock By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/portfolio-stocks/{{stockId}}",
              "host": ["{{baseUrl}}"],
              "path": ["portfolio-stocks", "{{stockId}}"]
            },
            "description": "Gets details of a single portfolio stock allocation"
          },
          "response": []
        },
        {
          "name": "Update Portfolio Stock",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"allocationPercentage\": 25,\n  \"customMarketPrice\": 180.00\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/portfolio-stocks/{{stockId}}",
              "host": ["{{baseUrl}}"],
              "path": ["portfolio-stocks", "{{stockId}}"]
            },
            "description": "Updates allocation percentage or custom market price for a portfolio stock and recalculates portfolio allocated_weight and is_complete"
          },
          "response": []
        },
        {
          "name": "Delete Portfolio Stock",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/portfolio-stocks/{{stockId}}",
              "host": ["{{baseUrl}}"],
              "path": ["portfolio-stocks", "{{stockId}}"]
            },
            "description": "Removes a stock allocation from a portfolio and updates portfolio allocated_weight and is_complete"
          },
          "response": []
        }
      ]

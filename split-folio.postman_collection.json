    {
      "name": "Portfolios CRUD",
      "item": [
        {
          "name": "Create Model Portfolio",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "if (jsonData && jsonData.id) {",
                  "    pm.collectionVariables.set('portfolioId', jsonData.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Tech Growth Model Portfolio\",\n  \"stocks\": [\n    {\n      \"ticker\": \"AAPL\",\n      \"allocationPercentage\": 60\n    },\n    {\n      \"ticker\": \"TSLA\",\n      \"allocationPercentage\": 40\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/portfolios",
              "host": ["{{baseUrl}}"],
              "path": ["portfolios"]
            },
            "description": "Creates a new model portfolio with validated 100% stock allocation, setting allocated_weight and is_complete status"
          },
          "response": []
        },
        {
          "name": "Get All Model Portfolios",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/portfolios",
              "host": ["{{baseUrl}}"],
              "path": ["portfolios"]
            },
            "description": "Retrieves all saved model portfolios with their stock allocations, allocated_weight, and is_complete"
          },
          "response": []
        },
        {
          "name": "Get Portfolio By ID",

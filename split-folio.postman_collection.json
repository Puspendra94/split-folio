          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Balanced Tech Portfolio\",\n  \"stocks\": [\n    {\n      \"ticker\": \"AAPL\",\n      \"allocationPercentage\": 50\n    },\n    {\n      \"ticker\": \"TSLA\",\n      \"allocationPercentage\": 50\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/portfolios/{{portfolioId}}",
              "host": ["{{baseUrl}}"],
              "path": ["portfolios", "{{portfolioId}}"]
            },
            "description": "Updates portfolio name and stock allocations, re-evaluating allocated_weight and is_complete"
          },
          "response": []
        },
        {
          "name": "Delete Portfolio",
          "request": {
            "method": "DELETE",
            "header": [],
